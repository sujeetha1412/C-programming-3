#include<stdio.h>
int main()
{
   int n,s=0,original,r;
   printf("Enter a number:");
   scanf("%d",&n);
   original=n;
   while(n>0)
   {
      r=n%10;
      s=(s*10)+r;
      n=n/10;
   }
   if(s==original)
   {
     printf("%d is palindrome",original);
   }
   else
   {
      printf("%d is not palindrome",original);
   }
   printf("\nFinished");
   return 0;
}
